# Optional: For AI-generated questions when "Generate more with AI" is checked
# Add one of these to .env.local (never commit .env.local):

# OpenAI (GPT-4o-mini)
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Note: The API key is only used when you explicitly enable "Generate more with AI"
# in the Add Job form. Real questions are fetched from the web first.
